{
    "name": "example/event-ticketing",
    "description": "Secure vanilla PHP event ticketing system with QR code registration and admin check-in.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "endroid/qr-code": "^5.1",
        "mongodb/mongodb": "^1.21"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "cs": "phpcs --standard=PSR12 src public"
    }
}
